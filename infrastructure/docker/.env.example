# Copier ce fichier en `.env` a cote du docker-compose.yml et adapter selon ton installation.
# --- Postgres natif (celui installe sur ta machine, PAS celui du compose "db") ---
OMNIAGENT_DB_USER=omniagent
OMNIAGENT_DB_PASSWORD=omniagent
OMNIAGENT_DB_NAME=omniagent
OMNIAGENT_DB_HOST=host.docker.internal
OMNIAGENT_DB_PORT=5432

# Compose complet
OMNIAGENT_DB_URL=postgresql+asyncpg://${OMNIAGENT_DB_USER}:${OMNIAGENT_DB_PASSWORD}@${OMNIAGENT_DB_HOST}:${OMNIAGENT_DB_PORT}/${OMNIAGENT_DB_NAME}