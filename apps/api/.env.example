APP_NAME=OmniAgent
ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://omniagent:omniagent@localhost:5432/omniagent
REDIS_URL=redis://localhost:6379/0

# LLM
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# Contact enrichment (optionnel, pour email RH via Hunter)
HUNTER_API_KEY=

# Filtering + Matching Agent (cle dediee)
FILTERING_MATCHING_AGENT_API_KEY=

# Mission Controller Agent (cle dediee)
MISSION_CONTROLLER_AGENT_API_KEY=

# Fiabilite connecteurs emploi (quotas / cache / backoff)
EMPLOYMENT_CONNECTOR_CACHE_TTL_S=300
EMPLOYMENT_CONNECTOR_MAX_RETRIES=2
EMPLOYMENT_CONNECTOR_BACKOFF_BASE_S=0.5

# Envoi candidature par email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=OmniAgent
APPLICATION_SENDER_CONFIRMATION_PHRASE=JE CONFIRME L ENVOI
APPLICATION_SENDER_REQUIRE_CV=true

# CV generation (agent_cv)
# 1 pour autoriser la compilation PDF via pdflatex, 0 pour ne generer que le .tex
OMNIAGENT_ENABLE_PDF_RENDER=1

# Messagerie

# Comptabilite

# Securite
SECRET_KEY=change-me-in-prod
CORS_ORIGINS=["http://localhost:3000"]

# ====================================================================
# France Travail (ex Pole Emploi) - API Offres Emploi v2
# Sprint 4 etape 1 : branchement connecteur plateforme emploi
# --------------------------------------------------------------------
# Comment obtenir les cles :
#   1. Creer un compte sur https://francetravail.io (gratuit)
#   2. Creer une application (menu "Mes applications")
#   3. Selectionner le scope "api_offresdemploiv2"
#   4. Recuperer client_id et client_secret (visibles 1 seule fois)
#
# Sans ces cles, le connecteur bascule automatiquement sur un mock
# (offres representatives). Voir /api/v1/shared/connectors/france_travail/health
# pour verifier le mode operationnel.
# ====================================================================
FT_CLIENT_ID=
FT_CLIENT_SECRET=
FT_SCOPE=api_offresdemploiv2 o2dsoffre

# Optionnels (defauts OK pour la prod)
# FT_BASE_URL=https://api.francetravail.io
# FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=%2Fpartenaire
# FT_CACHE_TTL=300
# FT_TIMEOUT=15
